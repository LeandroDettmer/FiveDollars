{
  "identifier": "default",
  "description": "Permissões padrão do FiveDollars",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://*:*" },
        { "url": "https://*:*" },
        { "url": "http://localhost:*" },
        { "url": "http://127.0.0.1:*" }
      ]
    }
  ]
}
